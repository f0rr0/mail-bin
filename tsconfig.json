{
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["DOM", "DOM.Iterable", "ESNext"],
		"jsx": "react-jsx",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"resolveJsonModule": true,
		"allowJs": false,
		"noEmit": true,
		"isolatedModules": true,
		"allowSyntheticDefaultImports": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"paths": {
			"@/*": ["./src/*"]
		},
		"types": [
			"vite/client",
			"./worker-configuration.d.ts",
			"@cloudflare/vitest-pool-workers/types",
			"node"
		]
	},
	"include": [
		"index.html",
		"drizzle.config.ts",
		"oxfmt.config.ts",
		"oxlint.config.ts",
		"scripts/**/*.ts",
		"src/**/*.ts",
		"src/**/*.tsx",
		"test/**/*.ts",
		"vite.config.ts",
		"vitest.config.mts",
		"worker-configuration.d.ts"
	]
}
