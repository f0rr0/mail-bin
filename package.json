{
	"name": "mail-bin",
	"version": "0.0.0",
	"private": true,
	"description": "Single-admin disposable email router for Cloudflare Email Routing.",
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"deploy": "vite build && bun run ./scripts/wrangler.ts deploy",
		"cf": "bun run ./scripts/wrangler.ts",
		"setup:cloudflare": "bun run ./scripts/init-cloudflare.ts",
		"cf:config:write": "bun run ./scripts/write-wrangler-config.ts",
		"cf:types": "bun run ./scripts/wrangler.ts types",
		"db:generate": "drizzle-kit generate",
		"db:migrate:local": "bun run ./scripts/wrangler.ts d1 migrations apply DB --local",
		"db:migrate:remote": "bun run ./scripts/wrangler.ts d1 migrations apply DB --remote",
		"lint": "ultracite check .",
		"lint:fix": "ultracite fix .",
		"lint:type-aware": "ultracite check --type-aware --tsconfig=./tsconfig.json .",
		"commitlint": "bun run ./scripts/check-commit-message.ts",
		"release:prepare": "bun run ./scripts/prepare-release.ts",
		"format": "oxfmt .",
		"format:check": "oxfmt --check .",
		"doctor": "ultracite doctor",
		"quality": "bun run lint",
		"quality:fix": "bun run lint:fix",
		"typecheck": "tsgo --noEmit",
		"test": "vite build && vitest run",
		"test:watch": "vitest",
		"verify": "bun run lint && bun run lint:type-aware && bun run typecheck && bun run test",
		"mail:fixture": "bun run ./scripts/replay-mail-fixture.ts ./fixtures/mail",
		"prepare": "lefthook install"
	},
	"dependencies": {
		"@hono/zod-openapi": "^1.3.0",
		"@hookform/resolvers": "^5.2.2",
		"@scalar/hono-api-reference": "^0.10.9",
		"@tanstack/react-query": "^5.99.2",
		"@tanstack/react-router": "^1.168.23",
		"@tanstack/react-table": "^8.21.3",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.14",
		"lucide-react": "^1.8.0",
		"nanoid": "^5.1.9",
		"radix-ui": "^1.4.3",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-hook-form": "^7.72.1",
		"shadcn": "^4.3.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.32.3",
		"@cloudflare/vitest-pool-workers": "0.14.7",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@typescript/native-preview": "^7.0.0-dev.20260419.1",
		"@vitejs/plugin-react": "^6.0.1",
		"drizzle-kit": "^0.31.10",
		"lefthook": "^2.1.6",
		"oxfmt": "^0.45.0",
		"oxlint": "^1.60.0",
		"oxlint-tsgolint": "^0.21.1",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.5.2",
		"ultracite": "^7.6.0",
		"vite": "^8.0.8",
		"vitest": "^4.1.0",
		"wrangler": "^4.83.0"
	},
	"packageManager": "bun@1.3.8"
}
